{
  "version": 2,
  "name": "pidunet-saas",
  "builds": [
    {
      "src": "servidor.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "servidor.js"
    },
    {
      "src": "/acceso",
      "dest": "/acceso.html"
    },
    {
      "src": "/inicio",
      "dest": "/inicio.html"
    },
    {
        "src": "/resumen",
        "dest": "/resumen.html"
    },
    {
      "src": "/",
      "dest": "/acceso.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
