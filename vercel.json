{
  "version": 2,
  "name": "pidunet-saas",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/inicio",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": false
    }
  ]
}
