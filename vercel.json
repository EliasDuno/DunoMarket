{
  "version": 2,
  "name": "pidunet-saas",
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/acceso",
      "destination": "/acceso.html"
    },
    {
      "source": "/inicio",
      "destination": "/inicio.html"
    },
    {
      "source": "/resumen",
      "destination": "/resumen.html"
    },
    {
      "source": "/",
      "destination": "/acceso.html"
    }
  ],
  "cleanUrls": true
}
