{
  "version": 2,
  "name": "pidunet-saas",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/acceso",
      "destination": "/acceso.html"
    },
    {
      "source": "/inicio",
      "destination": "/inicio.html"
    },
    {
      "source": "/resumen",
      "destination": "/resumen.html"
    },
    {
      "source": "/",
      "destination": "/acceso.html"
    }
  ],
  "cleanUrls": true
}
