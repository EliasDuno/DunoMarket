# Primary connection for the PiduNet master database.
# Use this value in Supabase/Vercel. Format:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# SSL is required for Supabase. Leave enabled when DATABASE_URL points to Supabase.
DB_SSL=true

# Optional local PostgreSQL fallback when DATABASE_URL is not set.
DB_USER=postgres
DB_HOST=localhost
DB_NAME=PiduNet
DB_PASSWORD=
DB_PORT=5432
